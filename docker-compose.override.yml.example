# =============================================================================
# docker-compose.override.yml — Local customizations (gitignored)
# =============================================================================
# This file is automatically loaded by Docker Compose alongside docker-compose.yml.
# It is listed in .gitignore, so your local changes will NOT be overwritten by updates.
#
# Use this file to override any service settings for your local environment.
#
# -----------------------------------------------------------------------------
# WSL2 FIX: Monitoring stack (node-exporter + cAdvisor) on WSL2
# -----------------------------------------------------------------------------
# SYMPTOM: After enabling the "monitoring" profile on WSL2, load average spikes
# above 900 and the SSH session freezes within seconds.
#
# ROOT CAUSE: Both node-exporter and cAdvisor are written in Go and traverse
# mounted filesystems to collect disk metrics. In WSL2 this includes Windows
# drives (/mnt/c, /mnt/d, ...) via the 9p/drvfs protocol. stat() calls on
# these paths hang indefinitely. Because Go collects metrics on a fixed interval
# without cancelling timed-out goroutines, each scrape spawns new blocked
# goroutines — resulting in load average >900 and a frozen SSH session.
#
# FIX: Uncomment the block below to apply WSL2-safe flags.
# This restricts both services from scanning Windows-mounted drives.
# DO NOT enable on native Linux servers — it disables disk metrics.
#

# Общая папка с данными (документы, аудио, видео) — только чтение
x-meeting-data: &meeting-data /mnt/e/meeting-data:/meeting-data:ro

services:

   gotenberg:
     volumes:
       - *meeting-data
     healthcheck:
       test: ["CMD", "curl", "-f", "-s", "http://localhost:3000/health"]
       interval: 30s
       timeout: 10s
       retries: 3

   uptime-kuma:
     healthcheck:
       test: ["CMD", "curl", "-f", "http://localhost:3001"]
       interval: 30s
       timeout: 10s
       retries: 3

   ollama-gpu:
     deploy:
       resources:
         reservations:
           devices:
             - driver: nvidia
               device_ids: ['1'] # Вторая карта на хосте (5070 Ti)
               capabilities: [gpu]
     ports:
       - "11434:11434"
     volumes:
       - ./storage-models/ollama:/root/.ollama
       - /mnt/d/models:/external-models:ro
     environment:
       - OLLAMA_HOST=0.0.0.0
       - OLLAMA_NUM_PARALLEL=1
       - OLLAMA_MAX_LOADED_MODELS=1
       - OLLAMA_FLASH_ATTENTION=1
       - OLLAMA_KV_CACHE_TYPE=q8_0
       - OLLAMA_CONTEXT_LENGTH=131072
       - OLLAMA_KEEP_ALIVE=5h
       - OLLAMA_SCHED_SPREAD=1
       # Внутри контейнера видна только одна карта — она всегда под индексом 0
       - CUDA_VISIBLE_DEVICES=0
       - NVIDIA_VISIBLE_DEVICES=0

   ollama-pull-llama-gpu:
     volumes:
       - ./storage-models/ollama:/root/.ollama
     environment:
       # Внутри контейнера видна только одна карта — она всегда под индексом 0
       - CUDA_VISIBLE_DEVICES=0
       - NVIDIA_VISIBLE_DEVICES=0
     deploy:
       resources:
         reservations:
           devices:
             - driver: nvidia
               device_ids: ['1'] # Та же вторая карта, чтобы не занимать первую
               capabilities: [gpu]

#запрет регистрации пользователей
   ragflow:
     environment:
       REGISTER_ENABLED: "0"
     volumes:
       - ./ragflow/nginx.conf:/etc/nginx/conf.d/ragflow.conf:ro
       - *meeting-data

#чуть подольше поднмаем базу для того, чтобы не спешили остальные контейнеры, кто проверяет хэлзичек - postiz например
   postgres:
     healthcheck:
      # Используем родную команду из твоего конфига
       test: ["CMD-SHELL", "pg_isready -U postgres"]
       interval: 10s
       timeout: 5s
       retries: 12
       start_period: 20s

#изменение базовых хэлзичеков
   databasus:
     healthcheck:
       test: ["CMD-SHELL", "bash -c 'exec 3<>/dev/tcp/127.0.0.1/4005' 2>/dev/null || exit 1"]
       interval: 30s
       timeout: 10s
       retries: 5
       start_period: 60s

   appsmith:
     healthcheck:
       test: ["CMD-SHELL", "http_proxy= https_proxy= HTTP_PROXY= HTTPS_PROXY= curl -f -s http://localhost/api/v1/health || exit 1"]

   comfyui:
     image: yanwk/comfyui-boot:cu130-slim-v2
     container_name: comfyui
     # Убираем --cpu, оставляем только то, что просил автор
     environment:
       - CLI_ARGS=--disable-xformers --listen 0.0.0.0
       # Видеть только видеокарту с номером 1
       - CUDA_VISIBLE_DEVICES=1
       - NVIDIA_VISIBLE_DEVICES=1
     # Точное повторение всех ключей -v из инструкции
     volumes:
       - ./storage:/root
       - ./storage-models/comfyui:/root/ComfyUI/models
       - ./storage-models/huggingface:/root/.cache/huggingface/hub
       - ./storage-models/torch-hub:/root/.cache/torch/hub
       - ./storage-user/input:/root/ComfyUI/input
       - ./storage-user/output:/root/ComfyUI/output
       - ./storage-user/workflows:/root/ComfyUI/user/default/workflows
     # Активация GPU (аналог --gpus только 1)
     deploy:
       resources:
         reservations:
           devices:
             - driver: nvidia
               device_ids: ['1']
               capabilities: [gpu]
     healthcheck:
       test: ["CMD-SHELL", "curl -f -s http://localhost:8188 > /dev/null || exit 1"]

   paddleocr:
     volumes:
       - *meeting-data
     healthcheck:
       test: ["CMD-SHELL", "curl -s http://localhost:8080 > /dev/null || exit 1"]
       start_period: 200s

   lightrag:
     volumes:
       - *meeting-data
     healthcheck:
       test: ["CMD-SHELL", "python3 -c 'import socket; s = socket.socket(); s.connect((\"localhost\", 9621))' || exit 1"]
       start_period: 120s

# устранение проблем зависания и доступа к дискам в WSL2
   node-exporter:
     init: true
     deploy:
       resources:
         limits:
           pids: 100
     command:
       - "--path.procfs=/host/proc"
       - "--path.sysfs=/host/sys"
       - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc|mnt|run|init|usr/lib/wsl)($|/)"
       - "--collector.filesystem.fs-types-exclude=^(autofs|binfmt_misc|bpf|cgroup2?|configfs|debugfs|devpts|devtmpfs|fusectl|hugetlbfs|iso9660|mqueue|nsfs|overlay|proc|procfs|pstore|rpc_pipefs|securityfs|selinuxfs|squashfs|sysfs|tracefs|9p|drvfs|tmpfs|rootfs)$"
       # Disable collectors that hang in WSL2 due to missing/broken netlink support
       - "--no-collector.arp"
       - "--no-collector.conntrack"
       - "--no-collector.wifi"

   cadvisor:
     cpus: "0.15"   # Не даст ему прыгать выше 15% одного ядра
     mem_limit: 256m
     command:
       - "--disable_metrics=disk,diskIO,tcp,udp,percpu,sched,process,hugetlb,referenced_memory,resctrl,advtcp,memory_numa"
       - "--docker_only=true"
       # Reduce polling frequency (default 1s is too aggressive for WSL2)
       - "--housekeeping_interval=60s"
       - "--global_housekeeping_interval=2m"
       # Skip root cgroup stats (can take 3-8s to read in WSL2)
       - "--disable_root_cgroup_stats=true"
       - "--v=1"
       - "--stderrthreshold=WARNING"
   
   clickhouse:
     volumes:
       # Добавляем только файл-глушилку, остальные диски подтянутся из основного файла
       - ./disable_syslogs.xml:/etc/clickhouse-server/config.d/disable_syslogs.xml:ro

# Монтирование общей папки с данными
   n8n:
     volumes:
       - *meeting-data

   docling:
     volumes:
       - *meeting-data

   crawl4ai:
     volumes:
       - *meeting-data

   flowise:
     volumes:
       - *meeting-data

   letta:
     volumes:
       - *meeting-data

   prometheus:
     command:
       - '--config.file=/etc/prometheus/prometheus.yml'
       - '--storage.tsdb.path=/prometheus'
       - '--storage.tsdb.retention.time=15d'
       - '--storage.tsdb.retention.size=2GB'

# Тест: фикс ARI ошибок Caddy - хардкодим IP Let's Encrypt
